# =============================================================================
# WireGuard Client-Konfiguration — OPNsense Hauptwohnsitz (Referenz)
#
# OPNsense übernimmt die Client-Rolle und verbindet sich aktiv zum Raspi-Server.
# Diese Datei dient nur als Referenz — OPNsense konfiguriert WireGuard
# über seine eigene WebUI (VPN → WireGuard → Instances + Peers).
#
# Entsprechende Anleitung: docs/OPNsense-WireGuard.md
# =============================================================================

[Interface]
# Privater Schlüssel des Clients (generiert von wireguard-ui oder: wg genkey)
PrivateKey = <CLIENT_PRIVATE_KEY>

# VPN-IP von OPNsense im Tunnel-Subnetz
Address = 10.10.0.3/24

# MTU: 1420 Standard; bei IPv6-Tunnel ggf. auf 1280 reduzieren
MTU = 1420

# DNS: OPNsense selbst oder Cloud-DNS
DNS = <HAUPT-GW>, 1.1.1.1

# iptables für Routing des Heimnetzes Nebenwohnsitz durch den Tunnel
# Interface anpassen! (eth0 = kabelgebunden, wlan0 = WLAN)
PostUp   = iptables  -A FORWARD -i wg0 -j ACCEPT; \
           iptables  -A FORWARD -o wg0 -j ACCEPT; \
           iptables  -t nat -A POSTROUTING -o eth0 -j MASQUERADE; \
           ip6tables -A FORWARD -i wg0 -j ACCEPT; \
           ip6tables -t nat -A POSTROUTING -o eth0 -j MASQUERADE

PostDown = iptables  -D FORWARD -i wg0 -j ACCEPT; \
           iptables  -D FORWARD -o wg0 -j ACCEPT; \
           iptables  -t nat -D POSTROUTING -o eth0 -j MASQUERADE; \
           ip6tables -D FORWARD -i wg0 -j ACCEPT; \
           ip6tables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

# =============================================================================
# Peer: Hauptwohnsitz (WireGuard-Server)
# =============================================================================

[Peer]
# Öffentlicher Schlüssel des Servers (Raspi) — aus wireguard-ui → Global Settings kopieren
PublicKey = <SERVER_PUBLIC_KEY>

# DDNS-Hostname des Raspi-Servers (AAAA-Record, von ddns-go gepflegt)
# WireGuard löst diesen IPv6-Hostnamen beim Verbindungsaufbau auf.
Endpoint = vpn.deine-domain.de:51820

# --- VARIANTE A: Split-Tunnel (empfohlen) ---
# Nur das Heimnetz Nebenwohnsitz und das VPN-Subnetz laufen durch den Tunnel.
# Normaler Internet-Traffic läuft direkt weiter.
AllowedIPs = 10.10.0.0/24, <NEBEN-LAN>

# --- VARIANTE B: Full-Tunnel (für Streaming-Dienste) ---
# ALLES läuft über den VPN-Tunnel.
# AllowedIPs = 0.0.0.0/0, ::/0

# Keepalive hält Tunnel durch Fritzbox-NAT und DS-Lite aktiv
PersistentKeepalive = 25
