# =============================================================================
# NEBENWOHNSITZ — Umgebungsvariablen
# Kopiere diese Datei nach .env und passe alle Werte an.
# NIEMALS die .env-Datei in Git committen!
# =============================================================================

# --- WireGuard-UI Login ---
WGUI_USERNAME=admin
# Sicheres Passwort wählen (min. 16 Zeichen)
WGUI_PASSWORD=CHANGEME_sicheres_Passwort_hier

# --- Session-Secret (zufälliger String, via: openssl rand -hex 32) ---
SESSION_SECRET=CHANGEME_openssl_rand_hex_32_ausgabe_hier

# --- DNS für den VPN-Tunnel ---
# 10.10.0.1 = OPNsense WireGuard-Interface (empfohlen für LAN-DNS)
# Bei Full-Tunnel kann OPNsense alle DNS-Anfragen beantworten.
WGUI_DNS=10.10.0.1,1.1.1.1

# --- MTU ---
# 1280 ist sicher für DS-Lite IPv6-Tunnel (Vodafone Kabel)
WGUI_MTU=1280

# --- DDNS (optional) ---
# Konfiguration über die ddns-go WebUI nach dem ersten Start:
# http://<raspi-ip>:9876
# Beispiel-Hostname: vpn-neben.DEINE-DOMAIN.de
# Record-Typ: AAAA (IPv6)
# Interface: eth0
