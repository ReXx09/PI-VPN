# =============================================================================
# NEBENWOHNSITZ — Umgebungsvariablen
# Kopiere diese Datei nach .env und passe alle Werte an.
# =============================================================================

# Zeitzone
TZ=Europe/Vienna

# Benutzer/Gruppe (Standard Raspberry Pi OS: uid=1000 gid=1000)
PUID=1000
PGID=1000

# --- DDNS (optional) ---
# Wenn du ddns-go am Nebenwohnsitz nutzt, konfiguriere es über die WebUI
# (http://<raspi-ip>:9876) nach dem ersten Start.
# Beispiel-Hostname: vpn-neben.DEINE-DOMAIN.de
