# =============================================================================
# HAUPTWOHNSITZ — Umgebungsvariablen
# Kopiere diese Datei nach .env und passe alle Werte an.
# NIEMALS die .env-Datei in Git committen!
# =============================================================================

# --- WireGuard-UI Login ---
WGUI_USERNAME=admin
# Sicheres Passwort wählen (min. 16 Zeichen)
WGUI_PASSWORD=CHANGEME_sicheres_Passwort_hier

# --- Session-Secret (zufälliger String, z. B. via: openssl rand -hex 32) ---
SESSION_SECRET=CHANGEME_openssl_rand_hex_32_ausgabe_hier

# --- DDNS-Hostname ---
# Der AAAA-DNS-Eintrag, den ddns-go aktuell hält.
# Dieser Hostname wird von den Clients als WireGuard-Endpoint verwendet.
# Beispiel: vpn-home.dein-domain.de
WGUI_ENDPOINT_HOSTNAME=vpn-home.DEINE-DOMAIN.de

# --- DNS für VPN-Clients ---
# Heimnetz-DNS oder öffentlicher DNS
# Beispiel: 192.168.10.1 für OPNsense als DNS
WGUI_DNS=192.168.10.1,1.1.1.1

# --- MTU ---
# 1280 ist sicher für Starlink IPv6-Tunnel (vermeidet Fragmentierung)
WGUI_MTU=1280
